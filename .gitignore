# ── macOS ──
.DS_Store
._*

# ── Node / Remotion ──
**/node_modules/
**/out/
**/remotion-*/
!**/remotion-*/src/

# ── AI coding assistant local dirs ──
# A multi-tool skills installer scatters symlink farms into the repo root.
# .agents/ holds the real skill store; the rest are just symlinks. None are tracked.
.adal/
.agent/
.agents/
.augment/
.claude/
.cline/
.codebuddy/
.codex/
.commandcode/
.continue/
.crush/
.cursor/
.factory/
.gemini/
.github/
.goose/
.junie/
.kilocode/
.kiro/
.kode/
.mcpjam/
.mux/
.neovate/
.openclaude/
.opencode/
.openhands/
.pi/
.pochi/
.qoder/
.qwen/
.roo/
.trae/
.vibe/
.windsurf/
.zencoder/

# ── Per-episode production / scratch dirs (applies to every NN-* episode) ──
# These hold heavy source/render media. Track only the folder marker (.gitkeep),
# never the contents. Add a `.gitkeep` file to keep an empty dir in git.
**/downloads/**
**/aigc/**
**/sample/**
**/capcut/**
**/recording/**
**/output/**
!**/.gitkeep

# ── Binary / media (belt-and-suspenders — matches anywhere) ──
*.mp4
*.mov
*.mp3
*.wav
*.m4a
*.aac
*.jpg
*.jpeg
*.png
*.gif
*.pdf
*.screenflow/
14-loop/tools/shots/
